# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lp_enrichment
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/lp_enrichment

# API Keys (required)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# AI Model Config
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# Rate Limiting
TAVILY_REQUESTS_PER_MINUTE=50
CLAUDE_REQUESTS_PER_MINUTE=30

# Pipeline Config
ENRICHMENT_CONCURRENCY=5
SCORING_CONCURRENCY=3
BATCH_SIZE=10

# Frontend
FRONTEND_URL=http://localhost:3000
